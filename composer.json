{
    "name": "joelseneque/data-table-modal",
    "description": "A Filament v5 form field that renders a condensed, interactive data table with a slide-over modal editor, inline editing, parent/child grouping, reordering, selection and bulk actions. Backed by either an Eloquent model or array state.",
    "keywords": [
        "filament",
        "laravel",
        "livewire",
        "data-table",
        "repeater",
        "form-field"
    ],
    "homepage": "https://github.com/joelseneque/data-table-modal",
    "license": "MIT",
    "authors": [
        {
            "name": "Joel Seneque",
            "email": "joel@coll.group",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0|^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Joelseneque\\DataTableModal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Joelseneque\\DataTableModal\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Joelseneque\\DataTableModal\\DataTableModalServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "audit": {
            "ignore": {
                "PKSA-ndkp-2znf-9m7c": "Dev dependency advisory; the consuming app pins its own Filament version."
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
